# === OPCIÓN A: Ollama (100% local, sin API key, sin ninguna empresa de por medio) ===
# 1. Instala Ollama desde https://ollama.com
# 2. Corre en tu terminal: ollama pull llama3.1
# 3. Deja Ollama corriendo (arranca solo como servicio en segundo plano)
LLM_API_KEY=ollama
LLM_MODEL=llama3.1
LLM_BASE_URL=http://localhost:11434/v1

# === OPCIÓN B: Groq (gratis en la nube, sin tarjeta) ===
# Descomenta estas 3 líneas y comenta las de arriba para usar Groq en vez de Ollama
# LLM_API_KEY=gsk_tu_key_de_groq_aqui
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=https://api.groq.com/openai/v1

# Carpeta donde ChromaDB persiste la base de datos vectorial
CHROMA_PERSIST_DIR=./data/chroma

# Máximo de resultados web por búsqueda
WEB_SEARCH_MAX_RESULTS=5

# Umbral de confianza (0-1): si la similitud de memoria es menor a esto,
# el sistema decide buscar en internet
MEMORY_CONFIDENCE_THRESHOLD=0.35

TAVILY_API_KEY=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