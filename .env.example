# Clave de la API de Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=tu_api_key_aqui

# Modelo a usar - revisa docs.claude.com para el nombre de modelo vigente
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Carpeta donde ChromaDB persiste la base de datos vectorial
CHROMA_PERSIST_DIR=./data/chroma

# Máximo de resultados web por búsqueda
WEB_SEARCH_MAX_RESULTS=5

# Umbral de confianza (0-1): si la similitud de memoria es menor a esto,
# el sistema decide buscar en internet
MEMORY_CONFIDENCE_THRESHOLD=0.35
